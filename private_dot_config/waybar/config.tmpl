{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/scratchpad",
        "mpris"
        // "custom/representation"
    ],
    // "modules-center": [
    //     "sway/window"
    // ],
    "modules-right": [
        "pulseaudio#speaker",
        "pulseaudio#mic",
        "custom/bt-profile",
        "bluetooth",
        "group/network-wlan",
        "group/network-lan",
        "group/network-tether",
        "cpu",
        "memory",
        "custom/temperature",
        "backlight",
        // "sway/language",
        "battery",
        // "custom/weather",
        "tray",
        "clock",
        "power-profiles-daemon",
        "idle_inhibitor",
        "custom/notification"
    ],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": [
            "",
            "´őĺ"
        ],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name}: {icon}",
        "persistent-workspaces": {
            "1": []
        },
        "format-icons": {
            "1": "´ëę", // browsing
            "2": "´äí", // coding
            "3": "´äá", // terminal
            "4": "ˇ░ŽĹ", // teams
            "10": "´äł", // external monitor
            "high-priority-named": [
                "1",
                "2",
                "3",
                "4",
                "10"
            ],
            "urgent": "´ü¬",
            "focused": "´ćĺ",
            "default": "´äĹ"
        }
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "´âž",
            "performance": "´âž",
            "balanced": "´ëÄ",
            "power-saver": "´üČ"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "{:%H:%M}",
        "on-click": "$HOME/.config/waybar/scripts/calendar-toggle.sh",
        "tooltip": false
    },
    "cpu": {
        "format": "{usage}% ´őŤ",
        "tooltip": true,
        "on-click": "wezterm -e --class htop htop"
    },
    "memory": {
        "format": "{}% ´öŞ",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G RAM\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "wezterm -e --class htop htop"
    },
    "custom/temperature": {
        "exec": "$HOME/.config/waybar/scripts/temperature.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": [
            "ţÄŹ",
            "ţĆô",
            "ţĆĹ",
            "ţĆĆ",
            "ţĆÄ",
            "ţĆŹ",
            "ţĆŐ",
            "ţĆł",
            "ţÄŤ"
        ]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´Śž",
        "format-plugged": "{capacity}% ´çŽ",
        "format-alt": "{time} {icon}",
        "format-good": "", // An empty format will hide the module
        "format-full": "",
        "tooltip-format": "{time} remaining\n{power:.1f}W",
        "tooltip-format-charging": "Charging: {capacity}%\n{power:.1f}W",
        "tooltip-format-plugged": "Plugged in: {capacity}%",
        "format-icons": [
            "´ëä",
            "´ëâ",
            "´ëé",
            "´ëü",
            "´ëÇ"
        ]
    },
    "bluetooth": {
        "on-click": "exec blueman-manager &",
        "format": "{status} ´Őö",
        "format-connected": "{status} ´Őö",
        "format-connected-battery": "­čöő{device_battery_percentage}% ´Őö",
        "tooltip-format": "{controller_alias}\n{controller_address}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\nBattery: {device_battery_percentage}%"
    },
    "group/network-wlan": {
        "orientation": "inherit",
        "modules": [
            "custom/network-wlan",
            "custom/network-wlan-detail"
        ],
        "drawer": {
            "transition-duration": 250,
            "transition-left-to-right": false,
            "children-class": "network-detail"
        }
    },
    "group/network-lan": {
        "orientation": "inherit",
        "modules": [
            "custom/network-lan",
            "custom/network-lan-detail"
        ],
        "drawer": {
            "transition-duration": 250,
            "transition-left-to-right": false,
            "children-class": "network-detail"
        }
    },
    "group/network-tether": {
        "orientation": "inherit",
        "modules": [
            "custom/network-tether",
            "custom/network-tether-detail"
        ],
        "drawer": {
            "transition-duration": 250,
            "transition-left-to-right": false,
            "children-class": "network-detail"
        }
    },
    "custom/network-lan": {
        "exec": "$HOME/.config/waybar/scripts/network-status.sh lan",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },
    "custom/network-lan-detail": {
        "exec": "$HOME/.config/waybar/scripts/network-status.sh lan detail",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },
    "custom/network-tether": {
        "exec": "$HOME/.config/waybar/scripts/network-status.sh tether",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },
    "custom/network-tether-detail": {
        "exec": "$HOME/.config/waybar/scripts/network-status.sh tether detail",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },
    "custom/network-wlan": {
        "exec": "$HOME/.config/waybar/scripts/network-status.sh wlan",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },
    "custom/network-wlan-detail": {
        "exec": "$HOME/.config/waybar/scripts/network-status.sh wlan detail",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },
    "pulseaudio#speaker": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}´Őö",
        "format-bluetooth-muted": "{volume}% {icon}´Őö",
        "format-muted": "{volume}% ´Üę",
        // "format-source": "{volume}%",
        // "format-source-muted": "",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": [
                "´ÇŽ",
                "´Çž",
                "´ÇĘ"
            ]
        },
        "on-click-right": "flatpak run com.saivert.pwvucontrol -t 4",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },
    "pulseaudio#mic": {
        "source": true,
        "format": "{format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "{volume}% ´ä▒",
        "tooltip-format": "Microphone: {source_desc}, {volume}%",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "flatpak run com.saivert.pwvucontrol -t 3",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+ --limit 1.0",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-"
    },
    "mpris": {
        "format": "{status_icon} {dynamic} {player_icon}",
        "format-paused": "{status_icon} <i>{dynamic}</i> {player_icon}",
        "dynamic-order": [
            "title",
            "artist",
            "album"
        ],
        "dynamic-separator": " - ",
        "dynamic-len": 40,
        "player-icons": {
            "default": "­čÄÁ",
            "firefox": "´ëę",
            "chromium": "´ëĘ",
            "google-chrome": "´ëĘ",
            "mpv": "­čÄČ",
            "spotify": "´ć╝",
            "vlc": "­čÄČ",
            "plexamp": "­čÄÁ",
            "plex": "­čÄČ"
        },
        "status-icons": {
            "paused": "´Őő",
            "playing": "´ůä",
            "stopped": "´ŐŹ"
        },
        "ignored-players": [],
        "tooltip-format": "{player} ({status}): {dynamic}"
    },
    "custom/weather": {
        "format": "{}",
        "exec": "$HOME/scripts/waybar-weather.sh",
        "interval": 1800,
        "return-type": "text",
        "tooltip": false,
        "on-click": "firefox --new-window $($HOME/scripts/yr-url-lookup.sh)"
    },
    "custom/bt-profile": {
        "format": "{}",
        "exec": "$HOME/scripts/waybar-bt-profile.sh",
        "on-click": "$HOME/scripts/a2dp-toggle.sh",
        "interval": 1,
        "return-type": "text",
        "tooltip": false
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon} ",
        "format-icons": {
            "notification": "<span foreground='yellow'>ţ«Ü</span>",
            "none": "<span foreground='white'>ţ¬ó</span>",
            "dnd-notification": "<span foreground='yellow'>ţ░ë</span>",
            "dnd-none": "<span foreground='grey'>ţ░ł</span>",
            "inhibited-notification": "<span foreground='yellow'>ţ«Ü</span>",
            "inhibited-none": "<span foreground='grey'>ţ¬ó</span>",
            "dnd-inhibited-notification": "<span foreground='yellow'>ţ░ë</span>",
            "dnd-inhibited-none": "<span foreground='grey'>ţ░ł</span>"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/representation": {
        "interval": 1,
        "exec": "swaymsg -t get_workspaces | jq -r '.[] | select(.focused==true)|.representation'",
        "signal": 11
    }
}