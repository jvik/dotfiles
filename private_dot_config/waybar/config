{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/scratchpad",
        "sway/mode",
        "mpris"
        // "custom/representation"
    ],
    // "modules-center": [
    //     "sway/window"
    // ],
    "modules-right": [
        "pulseaudio#speaker",
        "pulseaudio#mic",
        "custom/bt-profile",
        "bluetooth",
        "network",
        "cpu",
        "memory",
        "temperature",
        "backlight",
        // "sway/language",
        "battery",
        // "custom/weather",
        "tray",
        "custom/clock",
        "power-profiles-daemon",
        "idle_inhibitor",
        "custom/notification"
    ],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": [
            "",
            "яЛТ"
        ],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name}: {icon}",
        "persistent-workspaces": {
            "1": []
        },
        "format-icons": {
            "1": "яЙй", // browsing
            "2": "яДб", // coding
            "3": "яДа", // terminal
            "4": "ґ░жС", // teams
            "5": "яЖШ", // slack
            "8": "яАБ", // music
            "9": "яБ╡", // IM,
            "10": "яДИ", // external monitor
            "high-priority-named": [
                "1",
                "2",
                "3",
                "4",
                "5",
                "8",
                "9",
                "10"
            ],
            "urgent": "яБк",
            "focused": "яЖТ",
            "default": "яДС"
        }
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "яГз",
            "performance": "яГз",
            "balanced": "яЙО",
            "power-saver": "яБм"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "custom/clock": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/clock.sh",
        "interval": 1,
        "signal": 8,
        "on-click": "$HOME/.config/waybar/scripts/clock.sh toggle-date",
        "tooltip": false
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false,
        "on-click": "wezterm -e --class htop htop"
    },
    "memory": {
        "format": "{}% яГЙ",
        "on-click": "wezterm -e --class htop htop"
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": [
            "яЭл",
            "яЛЙ",
            "яЭй"
        ]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": [
            "юОН",
            "юПУ",
            "юПС",
            "юПП",
            "юПО",
            "юПН",
            "юПК",
            "юПИ",
            "юОЫ"
        ]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яЧз",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        "format-good": "", // An empty format will hide the module
        "format-full": "",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "bluetooth": {
        "on-click": "exec blueman-manager &",
        "format": "{status} яКФ",
        "format-connected": "{status} яКФ",
        "format-connected-battery": "ЁЯФЛ{device_battery_percentage}% яКФ",
        "tooltip-format": "{controller_alias}\n{controller_address}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\nBattery: {device_battery_percentage}%"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{signalStrength}% яЗл",
        "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-right": "wezterm -e --class nmwui nmtui"
    },
    "pulseaudio#speaker": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}яКФ",
        "format-bluetooth-muted": "{volume}% {icon}яКФ",
        "format-muted": "{volume}% яЪй",
        // "format-source": "{volume}%",
        // "format-source-muted": "",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        },
        "on-click-right": "flatpak run com.saivert.pwvucontrol -t 4",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ -l 1",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },
    "pulseaudio#mic": {
        "source": true,
        "format": "{format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "{volume}% яД▒",
        "tooltip-format": "Microphone: {source_desc}, {volume}%",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "flatpak run com.saivert.pwvucontrol -t 3",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+ --limit 1.0",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-"
    },
    "mpris": {
        "format": "{status_icon} {dynamic} {player_icon}",
        "format-paused": "{status_icon} <i>{dynamic}</i> {player_icon}",
        "dynamic-order": [
            "title",
            "artist",
            "album"
        ],
        "dynamic-separator": " - ",
        "dynamic-len": 40,
        "player-icons": {
            "default": "ЁЯО╡",
            "firefox": "яЙй",
            "chromium": "яЙи",
            "google-chrome": "яЙи",
            "mpv": "я┐╜",
            "spotify": "яЖ╝",
            "vlc": "ЁЯОм",
            "plexamp": "ЁЯО╡",
            "plex": "ЁЯОм"
        },
        "status-icons": {
            "paused": "яКЛ",
            "playing": "яЕД",
            "stopped": "яКН"
        },
        "ignored-players": [],
        "tooltip-format": "{player} ({status}): {dynamic}"
    },
    "custom/weather": {
        "format": "{}",
        "exec": "$HOME/scripts/waybar-weather.sh",
        "interval": 1800,
        "return-type": "text",
        "tooltip": false,
        "on-click": "firefox --new-window $($HOME/scripts/yr-url-lookup.sh)"
    },
    "custom/bt-profile": {
        "format": "{}",
        "exec": "$HOME/scripts/waybar-bt-profile.sh",
        "on-click": "$HOME/scripts/a2dp-toggle.sh",
        "interval": 1,
        "return-type": "text",
        "tooltip": false
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon} ",
        "format-icons": {
            "notification": "<span foreground='yellow'>юоЪ</span>",
            "none": "<span foreground='white'>юкв</span>",
            "dnd-notification": "<span foreground='yellow'>ю░Й</span>",
            "dnd-none": "<span foreground='grey'>ю░И</span>",
            "inhibited-notification": "<span foreground='yellow'>юоЪ</span>",
            "inhibited-none": "<span foreground='grey'>юкв</span>",
            "dnd-inhibited-notification": "<span foreground='yellow'>ю░Й</span>",
            "dnd-inhibited-none": "<span foreground='grey'>ю░И</span>"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/representation": {
        "interval": 1,
        "exec": "swaymsg -t get_workspaces | jq -r '.[] | select(.focused==true)|.representation'",
        "signal": 11
    }
}